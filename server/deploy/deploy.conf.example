# ============================================================
# 工大圈子 - 部署配置（一处修改，全局生效）
# ============================================================
# 用法：
#   1. cp deploy.conf.example deploy.conf
#   2. 编辑 deploy.conf，填入实际值
#   3. 运行 sudo ./setup-nginx.sh 自动生成 Nginx 配置
# ============================================================

# 部署模式：ip | cloudflare
#   ip          - 用户直接用 https://VPS_IP 访问（默认）
#   cloudflare  - 用户通过域名经 Cloudflare 访问，CF 回源到本机
DEPLOY_MODE=ip

# 服务器名（填 Nginx 的 server_name，对应用户访问用的 IP 或域名）
#   - DEPLOY_MODE=ip         → 填 VPS 公网 IP，如 123.45.67.89
#   - DEPLOY_MODE=cloudflare → 填 CF 上代理的子域名，如 app.yourdomain.com
SERVER_NAME=YOUR_VPS_IP

# 后端端口（与 server/.env 中的 PORT 一致）
BACKEND_PORT=3000

# SSL 证书路径（必填）
#   - DEPLOY_MODE=ip         → 填你原来的 IP/域名证书（比如代理转发自动生成的那个）
#   - DEPLOY_MODE=cloudflare → 填 Cloudflare Origin Certificate
#     （在 CF 面板 → SSL/TLS → Origin Server 签一个 15 年证书）
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# 管理后台路径（与 server/.env 中的 ADMIN_PATH 一致）
ADMIN_PATH=console-k8m2x7

# H5 前端静态文件目录
H5_ROOT_PATH=/opt/hit-circle/client/h5

# Nginx 上传大小限制
CLIENT_MAX_BODY_SIZE=30M
