# Supabase 配置（从 Supabase 项目设置 → API 获取）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT 密钥（生产环境请用长随机字符串，至少 32 位）
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-change-this-to-long-random-string

# 服务端口
PORT=3000

# 管理后台路径（随机字符串，防止被猜测）
ADMIN_PATH=console-k8m2x7

# HTTPS 代理（仅本地开发需要）
# 如果服务器在墙外，留空即可
# HTTPS_PROXY=

# ============ Resend 邮件服务（邮箱验证码用）============
# 在 https://resend.com 注册后获取，格式 re_xxx
RESEND_API_KEY=re_your_api_key_here

# 发件人地址
#   测试期用: 工大圈子 <onboarding@resend.dev>
#   上线后用: 工大圈子 <noreply@yourdomain.com>（需在 Resend 验证域名）
EMAIL_FROM=工大圈子 <onboarding@resend.dev>

# ============ Anti-Abuse Phase 1：限流 & 人机验证 ============
# 部署模式：影响真实 IP 解析策略
# 可选值：ip | cloudflare | cloudflare-split
# 必须与 server/deploy/deploy.conf 里的 DEPLOY_MODE 保持一致
DEPLOY_MODE=ip

# Upstash Redis Cloud（注册 https://upstash.com/，选 Tokyo 区）
# 详见 docs/anti-abuse/08-deployment.md 第 A.1 节
UPSTASH_REDIS_REST_URL=https://tokyo-xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Cloudflare Turnstile（人机验证，免费）
# 详见 docs/anti-abuse/08-deployment.md 第 A.2 节
# 开发测试可用官方永远通过的 key: 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# 开关：设为 'false' 可在 CI/本地完全禁用 Turnstile 校验（不影响生产）
# 默认 true（生产、预发必须开）
TURNSTILE_ENABLED=true

# 限流开关：测试环境设为 'false' 可跳过 Redis 限流
RATE_LIMIT_ENABLED=true
